@using Sandbox;
@using Sandbox.UI;
@inherits Panel
@namespace Sandbox
@implements IUtilityTab
@attribute [Icon("🌍")]
@attribute [Title("World")]
@attribute [Order(0)]

<root class="tab">
    <div class="left">
        <VerticalMenu class="menuinner">
            <Options>
                @foreach ( var group in Game.TypeLibrary.GetTypes<UtilityFunction>().GroupBy( x => x.Group ).OrderBy( x => x.Min( t => t.Order ) ) )
                {
                    @if ( !string.IsNullOrWhiteSpace( group.Key ) )
                    {
                        <h2>@group.Key</h2>
                    }

                    @foreach ( var type in group.OrderBy( x => x.Order ).ThenBy( x => x.Title ) )
                    {
                        if ( type.IsAbstract ) continue;

                        var instance = type.Create<UtilityFunction>();
                        if ( instance is null || !instance.IsVisible() ) continue;

                        <MenuOption Text="@type.Title" Icon="@type.Icon"
                            class=@( SelectedFunctionType == type ? "active" : "" )
                            @onclick="@(() => OnSelect( type, instance ))">
                        </MenuOption>
                    }
                }
            </Options>
        </VerticalMenu>
    </div>

    <div class="body menuinner" @ref="PageContainer"></div>
</root>

@code
{
    TypeDescription SelectedFunctionType { get; set; }
    Panel PageContainer;
    List<UtilityPage> ActivePages = new();

    void OnSelect( TypeDescription type, UtilityFunction instance )
    {
        var pages = GetPages( type );

        if ( pages.Count > 0 )
        {
            SelectedFunctionType = type;

            foreach ( var p in ActivePages ) p.Delete();
            ActivePages.Clear();

            foreach ( var pageType in pages )
            {
                var page = pageType.Create<UtilityPage>();
                PageContainer.AddChild( page );
                ActivePages.Add( page );
            }
        }
        else
        {
            SelectedFunctionType = null;
            foreach ( var p in ActivePages ) p.Delete();
            ActivePages.Clear();
            instance.Execute();
        }

        StateHasChanged();
    }

    List<TypeDescription> GetPages( TypeDescription functionType )
    {
        return Game.TypeLibrary.GetTypes<UtilityPage>()
            .Where( t => !t.IsAbstract )
            .Where( t => t.GetAttribute<UtilityOfAttribute>()?.FunctionType == functionType.TargetType )
            .OrderBy( t => t.Order )
            .ThenBy( t => t.Title )
            .ToList();
    }
}
